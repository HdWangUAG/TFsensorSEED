# TFsensorSEED external-tool configuration.
# Copy to `.env` and edit for your machine/container. Both the Python pipeline
# (tfsensor/config.py) and the bash driver (drive_stage3.sh) read this file.
# Precedence: real environment variable > .env entry > built-in default below.
# `~` and $VARS are expanded.

# Repo root (defaults to the location of the package).
#TFSENSOR_REPO_ROOT=~/TFsensorSEED

# Shared LC-Seed checkout that hosts the per-task virtualenvs.
TFSENSOR_LC_SEED=~/LC-Seed

# --- LigandMPNN (Tier-0 generation) ---
TFSENSOR_LMPNN_REPO=~/my_ligandmpnn
TFSENSOR_LMPNN_RUN=~/my_ligandmpnn/run.py
TFSENSOR_LMPNN_CKPT=~/my_ligandmpnn/model_params/ligandmpnn_v_32_010_25.pt
TFSENSOR_LMPNN_PY=~/LC-Seed/envs/ligandmpnn/.venv/bin/python

# --- PyRosetta (Tier-1 flex-ddG) ---
TFSENSOR_PYROSETTA_PY=~/LC-Seed/envs/pyrosetta/.venv/bin/python

# --- Boltz-2 (Tier-1.5 gate) ---
TFSENSOR_BOLTZ_BIN=~/LC-Seed/envs/boltz2/.venv/bin/boltz

# --- driver runtime knobs (also plain env vars to drive_stage3.sh) ---
#NUM_GPUS=2        # Boltz lanes; default = number of detected GPUs
#SEEDS=1 42        # space-separated Boltz seeds per design
#N_SEQS=1000
#TOP=20

# === MiniCrewAI (multi-agent discussion runner) ============================
# Claude via the local `claude` CLI (Claude Code SUBSCRIPTION — no API key, no
# per-token cost). This is the `claude_cli` alias; nothing to set if `claude` is
# on PATH. Optionally pin the binary path / a --model value:
#MINICREW_CLAUDE_CLI_BIN=claude
#MINICREW_CLAUDE_CLI_MODEL=          # "" = subscription default
#
# API keys per provider (the `claude`/`openai`/`gemini`/`edinburgh` aliases).
# Set the ones you have; unset providers are skipped. The `claude` alias below
# is the raw-HTTP-API path (billed separately from the subscription).
#MINICREW_ANTHROPIC_API_KEY=sk-ant-...
#MINICREW_OPENAI_API_KEY=sk-...
#MINICREW_GEMINI_API_KEY=...
# University of Edinburgh language-model gateway (OpenAI-compatible). Point the
# base_url at the ELM /v1 endpoint and supply your key + the served model id.
#MINICREW_EDINBURGH_API_KEY=...
#MINICREW_EDINBURGH_BASE_URL=https://<elm-host>/v1
#MINICREW_EDINBURGH_MODEL=gpt-4o
# Override the concrete model id behind each alias (defaults shown):
#MINICREW_CLAUDE_MODEL=claude-opus-4-8
#MINICREW_GEMINI_MODEL=gemini-2.0-flash
#MINICREW_OPENAI_MODEL=gpt-4o
# Generation knobs:
#MINICREW_MAX_TOKENS=1024
#MINICREW_TEMPERATURE=0.7
